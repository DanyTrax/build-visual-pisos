# Copia este archivo como .env en la carpeta del stack de Dockge

REPLICATE_API_TOKEN=r8_tu_token_de_replicate

REPLICATE_MODEL=schananas/grounded_sam:ee871c19efb1941f55f66a3d7d960428c8a5afcb77449547fe8e5a3ab9ebc21c
FLOOR_TEXT_PROMPT=floor, ground, flooring
NEGATIVE_MASK_PROMPT=furniture, wall, person, rug
DETECTION_THRESHOLD=0.30
BOX_THRESHOLD=0.25
MAX_IMAGE_WIDTH=1280
ENABLE_FALLBACK_HEURISTIC=true
MASK_FEATHER_PX=11
BLEND_STRENGTH=0.75

ALLOWED_ORIGINS=*
JWT_EXPIRES_MIN=720

# Llaves random generadas por Docker en data/secrets.json (primer arranque)
AUTO_GENERATE_SECRETS=true
ADMIN_BOOTSTRAP_EMAIL=admin@tudominio.com

# Dentro del contenedor siempre es /app/data
DATA_DIR=/app/data

# Puertos publicos en el servidor
API_PORT=8001
WEB_PORT=8090
