REPLICATE_API_TOKEN=

# Modelo recomendado para deteccion automatica de piso.
REPLICATE_MODEL=schananas/grounded_sam:ee871c19efb1941f55f66a3d7d960428c8a5afcb77449547fe8e5a3ab9ebc21c
FLOOR_TEXT_PROMPT=floor, ground, flooring
NEGATIVE_MASK_PROMPT=furniture, wall, person, rug
DETECTION_THRESHOLD=0.30
BOX_THRESHOLD=0.25
MAX_IMAGE_WIDTH=1280
ENABLE_FALLBACK_HEURISTIC=true
MASK_FEATHER_PX=11
BLEND_STRENGTH=0.75

# Seguridad app
ALLOWED_ORIGINS=*
JWT_SECRET=change-this-secret
JWT_EXPIRES_MIN=720

# Bootstrap de primer admin (opcional)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!
DATA_DIR=./data
